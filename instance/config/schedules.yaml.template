# Task schedule profiles — controls how frequently Snowflake Tasks run.
#
# Rename this file to schedules.yaml after reviewing values.
# The "prod" profile is realistic for steady-state monitoring.
# The "demo" profile runs every 15 min to quickly populate dashboard graphs.

profiles:
  prod:
    description: "Production schedule — realistic intervals for steady-state monitoring"
    tasks:
      usage_aggregation:
        name: TASK_DAILY_USAGE_AGGREGATION
        schedule: "USING CRON 0 2 * * * UTC"
        description: "Aggregate token/request metrics daily at 2am UTC"
      feedback_analysis:
        name: TASK_DAILY_FEEDBACK_ANALYSIS
        schedule: "USING CRON 15 2 * * * UTC"
        description: "Run sentiment analysis on new feedback at 2:15am UTC"
      health_checks:
        name: TASK_DAILY_HEALTH_CHECKS
        schedule: "USING CRON 0 6 * * * UTC"
        description: "Run health checks daily at 6am UTC"
      weekly_sv_eval:
        name: TASK_WEEKLY_SV_EVAL
        schedule: "USING CRON 0 4 * * 0 UTC"
        description: "Semantic view smoke test every Sunday at 4am UTC"
      weekly_agent_eval:
        name: TASK_WEEKLY_AGENT_EVAL
        schedule: "USING CRON 0 5 * * 0 UTC"
        description: "Agent smoke test every Sunday at 5am UTC"

  demo:
    description: "Demo schedule — frequent runs (every 15 min) to quickly populate dashboard graphs"
    tasks:
      usage_aggregation:
        name: TASK_DAILY_USAGE_AGGREGATION
        schedule: "USING CRON */15 * * * * UTC"
        description: "Aggregate token/request metrics every 15 minutes"
      feedback_analysis:
        name: TASK_DAILY_FEEDBACK_ANALYSIS
        schedule: "USING CRON 5,20,35,50 * * * * UTC"
        description: "Run sentiment analysis every 15 minutes (offset by 5 min)"
      health_checks:
        name: TASK_DAILY_HEALTH_CHECKS
        schedule: "USING CRON 10,25,40,55 * * * * UTC"
        description: "Run health checks every 15 minutes (offset by 10 min)"
      weekly_sv_eval:
        name: TASK_WEEKLY_SV_EVAL
        schedule: "USING CRON */15 * * * * UTC"
        description: "Semantic view eval every 15 minutes"
      weekly_agent_eval:
        name: TASK_WEEKLY_AGENT_EVAL
        schedule: "USING CRON */15 * * * * UTC"
        description: "Agent eval every 15 minutes"
